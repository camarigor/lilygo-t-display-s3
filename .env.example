# =============================================================================
#  .env.example — TEMPLATE
#  1) Copie pra .env:          cp .env.example .env
#  2) Preencha com SEUS valores (escolha IDs e topology livremente)
#  3) NUNCA commite .env (gitignored)
#  4) scripts/generate-secrets.sh + scripts/generate-envs.sh derivam o resto
# =============================================================================

# ─── Hosts ───────────────────────────────────────────────────────────────────
# Lista de IDs separada por vírgula. IDs são slugs livres
# (letras minúsculas, dígitos, hífen; sem espaço ou acento).
#
# Cada ID gera automaticamente:
#   - hostname em tópicos MQTT:   stats/<id>/*, backups/<id>/*
#   - user MQTT:                  collector-<id>
#   - secret file:                secrets/collector-<id>.pass
#   - entrada em HOSTS[] no firmware C++
#
# Pra cada ID em HOSTS, defina abaixo:
#   HOST_<id>_LABEL    = display label (≤16 chars maiúsculo)
#   HOST_<id>_IP       = endereço IP que o broker MQTT enxerga
#   HOST_<id>_COLLECT  = system | snmp | none
#                        system: agente Telegraf coleta no próprio host
#                        snmp:   coletor externo faz SNMP polling deste host
#                        none:   listado pra UI mas sem coleta automática
#
# Exemplo:
# HOSTS=host-a,host-b,gateway
# HOST_host-a_LABEL="HOST A"
# HOST_host-a_IP=192.0.2.10
# HOST_host-a_COLLECT=system
# HOST_host-b_LABEL="HOST B"
# HOST_host-b_IP=192.0.2.20
# HOST_host-b_COLLECT=system
# HOST_gateway_LABEL="GATEWAY"
# HOST_gateway_IP=192.0.2.1
# HOST_gateway_COLLECT=snmp
HOSTS=

# ─── Papéis especiais (cada um referencia 1 ID em HOSTS) ─────────────────────
# Host que roda o broker MQTT (Mosquitto):
MQTT_BROKER_HOST=
# Host onde rodam os daemons companion (D-Bus listener + Claude usage + backup watcher).
# Tipicamente o desktop local do usuário (precisa de session bus D-Bus ativo).
COMPANION_HOST=
# Host destino de backup rsync (opcional). Se setado + BACKUP_LOG_PATH preenchido,
# companion daemon publica backups/<COMPANION_HOST>/last-run.
BACKUP_DEST_HOST=

# ─── MQTT ────────────────────────────────────────────────────────────────────
MQTT_PORT=1883

# ─── Weather ─────────────────────────────────────────────────────────────────
# Lista de city IDs separados por vírgula. Pra cada ID:
#   WEATHER_<id>_LABEL = display label (com aspas duplas se tiver espaço)
#   WEATHER_<id>_LAT   = latitude
#   WEATHER_<id>_LON   = longitude
#
# Exemplo:
# WEATHER_CITIES=city-a,city-b
# WEATHER_city-a_LABEL="CITY A"
# WEATHER_city-a_LAT=
# WEATHER_city-a_LON=
WEATHER_CITIES=
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
WEATHER_POLL_INTERVAL_S=600

# ─── Backups via rsync (só ativa se BACKUP_DEST_HOST e BACKUP_LOG_PATH setados)
BACKUP_LOG_PATH=
BACKUP_BATCH_SIZE=
BACKUP_BATCH_IDLE_SECONDS=

# ─── Topic prefixes (defaults sensatos; mexer só se quiser namespace diferente)
TOPIC_PREFIX_STATS=stats
TOPIC_PREFIX_BACKUPS=backups
TOPIC_PREFIX_WEATHER=data/weather
TOPIC_PREFIX_NOTIFICATIONS=notifications
TOPIC_CLAUDE_USAGE=claude/usage
TOPIC_DISPLAY_HEALTH=display/health
TOPIC_DISPLAY_STATUS=display/status
TOPIC_DISPLAY_FW_STATUS=display/firmware-status
TOPIC_CONTROL_FW_MANIFEST=control/display/firmware-manifest

# ─── MQTT users (os de coletor por host são derivados auto como collector-<id>)
MQTT_USER_ADMIN=admin
MQTT_USER_COLLECTOR_DATA=collector-data
MQTT_USER_DISPLAY=display-tdisplay

# ─── SNMP (pra hosts com COLLECT=snmp) ───────────────────────────────────────
SNMP_COMMUNITY=
SNMP_VERSION=2c

# ─── Wi-Fi (vazio = AP fallback captive portal no primeiro boot) ─────────────
WIFI_DEFAULT_SSID=
WIFI_DEFAULT_PASS=

# ─── OTA (servidor reside no MQTT_BROKER_HOST) ───────────────────────────────
FIRMWARE_SERVER_PORT=8081
FIRMWARE_VERSION_DEFAULT=1.0.0

# ─── Misc ────────────────────────────────────────────────────────────────────
# Ex: America/Sao_Paulo, Europe/Berlin, UTC
TZ=
NTP_SERVER=pool.ntp.org
LOG_LEVEL=INFO
