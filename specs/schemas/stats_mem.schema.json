{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stats/<host>/mem",
  "type": "object",
  "required": ["ts", "total_mb", "used_mb", "used_pct"],
  "properties": {
    "ts":        { "type": "integer", "minimum": 0 },
    "total_mb":  { "type": "integer", "minimum": 1 },
    "used_mb":   { "type": "integer", "minimum": 0 },
    "used_pct":  { "type": "number", "minimum": 0, "maximum": 100 }
  },
  "additionalProperties": false
}
