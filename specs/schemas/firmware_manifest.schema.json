{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "control/display/firmware-manifest",
  "type": "object",
  "required": ["latest_version", "url", "sha256", "size_bytes"],
  "properties": {
    "latest_version":     { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "released_at":        { "type": "integer", "minimum": 0 },
    "url":                { "type": "string", "minLength": 7 },
    "sha256":             { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "size_bytes":         { "type": "integer", "minimum": 1024 },
    "min_supported_from": { "type": "string", "maxLength": 16 },
    "notes":              { "type": "string", "maxLength": 1024 }
  },
  "additionalProperties": false
}
